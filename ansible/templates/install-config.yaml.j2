---
apiVersion: v1
metadata:
  name: {{ cluster_name }}
baseDomain: {{ base_domain }}

networking:
  networkType: OVNKubernetes
  machineNetwork:
    - cidr: {{ machine_network }}
  serviceNetwork:
    - {{ service_network }}
  clusterNetwork:
    - cidr: {{ pod_network }}
      hostPrefix: 23

compute:
  - name: worker
    replicas: {{ worker_nodes | length }}
    architecture: amd64

controlPlane:
  name: master
  replicas: {{ master_nodes | length }}
  architecture: amd64

platform:
  baremetal:
    apiVIPs:
      - {{ api_vip }}
    ingressVIPs:
      - {{ ingress_vip }}

pullSecret: '{{ lookup("file", pull_secret_path) }}'
sshKey: '{{ lookup("file", ssh_public_key_path) }}'

