---
apiVersion: v1
metadata:
  name: {{ cluster_name }}
baseDomain: {{ base_domain }}

networking:
  networkType: OVNKubernetes
  machineNetwork:
    - cidr: {{ machine_network }}
    - cidr: {{ machine_network_ipv6 }}
  serviceNetwork:
    - {{ service_network }}
    - {{ service_network_ipv6 }}
  clusterNetwork:
    - cidr: {{ pod_network }}
      hostPrefix: 23
    - cidr: {{ pod_network_ipv6 }}
      hostPrefix: 64

compute:
  - name: worker
    replicas: {{ worker_nodes | length }}
    architecture: amd64

controlPlane:
  name: master
  replicas: {{ controlplane_nodes | length }}
  architecture: amd64

platform:
{% if cluster_flavor == 'sno' %}
  none: {}
{% else %}
  baremetal:
    provisioningNetwork: Disabled
    apiVIPs:
      - {{ api_vip }}
      - {{ api_vip_ipv6 }}
    ingressVIPs:
      - {{ ingress_vip }}
      - {{ ingress_vip_ipv6 }}
    hosts:
{% for node in (controlplane_nodes + worker_nodes) %}
      - name: {{ node.hostname }}
        role: {{ node.role }}
        bmc:
          address: "redfish-virtualmedia://{{ sushy_host }}:{{ sushy_port }}/redfish/v1/Systems/{{ node.redfish_system_id }}"
          username: {{ redfish_username }}
          password: {{ redfish_password }}
          disableCertificateVerification: true
        bootMACAddress: {{ node.mac }}
        rootDeviceHints:
          deviceName: /dev/vda
{% endfor %}
{% endif %}


pullSecret: '{{ lookup("file", pull_secret_path) }}'
sshKey: '{{ ssh_public_key }}'
