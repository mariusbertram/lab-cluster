---
# =============================================================================
# Global variables for the LAP-Cluster
# Single source of truth for Terraform and Ansible
# =============================================================================

# ---------- Infrastructure (Terraform) ----------
libvirt_uri: "qemu:///system"
kvm_host: "localhost"
kvm_user: "root"
network_name: "bridged-network"
storage_pool_path: "/var/lib/libvirt/images/ocp"
# This is where libvirt expects the ISO on the KVM host
agent_iso_path: "/var/lib/libvirt/images/agent.x86_64.iso"

# ---------- Cluster Basics ----------
cluster_type: "talos" # Options: openshift, talos
cluster_name: "talos"
base_domain: "lab.brtrm.dev"
ocp_version: "4.21.8"
talos_version: "v1.12.6"
talos_cni: "flannel" # Options: flannel, calico, cilium
talos_vip_interface: "enp1s0" # Default interface for libvirt VMs
cluster_flavor: "standard" # Options: standard, compact, sno

# ---------- Network ----------
cluster_network_cidr: "192.168.150.0/24"
cluster_network_gateway: "192.168.150.1"
cluster_network_dns: "192.168.150.1"
api_vip: "192.168.150.10"
ingress_vip: "192.168.150.11"

# IPv6 Configuration (fd60::1/64)
cluster_ipv6_cidr: "fd60::/64"
cluster_ipv6_gateway: "fd60::1"
cluster_ipv6_dns: "fd60::1"
api_vip_ipv6: "fd60::10"
ingress_vip_ipv6: "fd60::11"

machine_network: "192.168.150.0/24"
machine_network_ipv6: "fd60::/64"
service_network: "172.30.0.0/16"
service_network_ipv6: "fdff:10:128::/112"
pod_network: "10.128.0.0/14"
pod_network_ipv6: "fd02:10:128::/48"

# ---------- Node Definitions ----------
nodes:
  controlplanes:
    - name: "controlplane-0"
      vcpu: 8
      memory: 16384
      disk_size: 150
      mac: "52:54:00:aa:bb:01"
      ip: "192.168.150.20"
      ipv6: "fd60::20"
    - name: "controlplane-1"
      vcpu: 8
      memory: 16384
      disk_size: 150
      mac: "52:54:00:aa:bb:02"
      ip: "192.168.150.21"
      ipv6: "fd60::21"
    - name: "controlplane-2"
      vcpu: 8
      memory: 16384
      disk_size: 150
      mac: "52:54:00:aa:bb:03"
      ip: "192.168.150.22"
      ipv6: "fd60::22"
  workers:
    - name: "worker-0"
      vcpu: 4
      memory: 16384
      disk_size: 150
      mac: "52:54:00:aa:cc:01"
      ip: "192.168.150.30"
      ipv6: "fd60::30"
    - name: "worker-1"
      vcpu: 4
      memory: 16384
      disk_size: 150
      mac: "52:54:00:aa:cc:02"
      ip: "192.168.150.31"
      ipv6: "fd60::31"
    - name: "worker-2"
      vcpu: 4
      memory: 16384
      disk_size: 150
      mac: "52:54:00:aa:cc:03"
      ip: "192.168.150.32"
      ipv6: "fd60::32"

# ---------- Paths (Local & Remote) ----------
# Local path on the control node (EE) for generating configs
local_workdir: "{{ playbook_dir }}/../.ocp_workdir"
local_bin_dir: "{{ local_workdir }}/bin"
pull_secret_path: "{{ local_workdir }}/pull-secret.json"

# Remote path on KVM host
remote_iso_path: "{{ agent_iso_path }}"

# ---------- SSH Key ----------
ssh_public_key: "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIPrmvsaHsLHQ9gMVq1m0xzdmTzfz7OulHr9/AB4XTQbS"

# ---------- OpenShift Installer URLs ----------
openshift_installer_url: "https://mirror.openshift.com/pub/openshift-v4/x86_64/clients/ocp/{{ ocp_version }}/openshift-install-linux.tar.gz"
oc_client_url: "https://mirror.openshift.com/pub/openshift-v4/x86_64/clients/ocp/{{ ocp_version }}/openshift-client-linux.tar.gz"
# ---------- Redfish Configuration ----------
sushy_host: "10.100.0.16"
sushy_port: 8443
sushy_protocol: "https"
redfish_username: "admin"
redfish_password: "admin"
iso_http_port: 8080
iso_reachable_ip: "10.100.0.16" # IP of the KVM host reachable by the nodes

# ---------- Unifi (API Token Auth) ----------
unifi_base_url: "https://192.168.1.1"
# Best practice: Set this via environment variable UBIQUITI_API_TOKEN
unifi_token: "{{ lookup('env', 'UBIQUITI_API_TOKEN') | default('TOPE_qC2JzT-v9V_SChDOCUMry32ixju') }}"
unifi_site_name: "Default"
unifi_network_name: "lab-ocp" # Name of your VLAN 13 network in UniFi
unifi_verify_ssl: false
